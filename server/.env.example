# Puerto del backend Express.
PORT=3000

# Conexion PostgreSQL usada por server/db.js.
# En Supabase suele requerir SSL; usa DB_SSL=require salvo que tu host no lo soporte.
DB_USER=usuario_postgres
DB_PASSWORD=contrasena_postgres
DB_HOST=host_postgres_supabase
DB_PORT=5432
DB_NAME=postgres
DB_SSL=require

# Secreto largo para firmar tokens JWT. No usar este placeholder en produccion.
JWT_SECRET=frase_larga_y_segura

# URL publica del frontend para enlaces de recuperacion de contrasena.
FRONTEND_URL=http://localhost:5500

# Resend es opcional. Si queda pendiente, no se enviaran correos reales.
RESEND_API_KEY=PENDIENTE_CONFIGURAR

# Supabase Storage es opcional. Si falta, las imagenes quedan como Base64.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_publica

# Variables opcionales del servidor estatico local.
FRONTEND_PORT=5500
CARTILLA_SKIP_BACKEND_AUTOSTART=0

# Solo para scripts de diagnostico manual server/test-*.
# No son requeridas para iniciar la aplicacion.
SUPABASE_PROJECT_REF=tu_project_ref
SUPABASE_POOLER_HOST=aws-0-region.pooler.supabase.com
DATABASE_URL=
